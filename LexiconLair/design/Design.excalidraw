      "updated": 1776705809050,
      "link": null,
      "locked": false,
      "text": "Lexicon Lair\nLexiconLair is an online platform that allows users to enter words they do not know the meaning of, that they read in books \ninto a website portal so they can get dictionary results. They can view words others have entered for book also. Words are organized by books and authors. \nThey can also add reviews and ratings to books. \n\n",
      "fontSize": 20,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 143,
      "containerId": null,
      "originalText": "Lexicon Lair\nLexiconLair is an online platform that allows users to enter words they do not know the meaning of, that they read in books \ninto a website portal so they can get dictionary results. They can view words others have entered for book also. Words are organized by books and authors. \nThey can also add reviews and ratings to books. \n\n",
      "lineHeight": 1.25
    },
